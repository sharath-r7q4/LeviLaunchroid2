<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/nav_bar_root"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical">

    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="48dp"
        android:paddingStart="12dp"
        android:paddingEnd="12dp">

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="match_parent"
            android:layout_gravity="start|center_vertical"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <ImageView
                android:id="@+id/nav_back_button"
                android:layout_width="28dp"
                android:layout_height="28dp"
                android:layout_marginEnd="10dp"
                android:src="@drawable/ic_arrow_down"
                android:rotation="90"
                android:scaleType="centerInside"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:clickable="true"
                android:focusable="true"
                app:tint="@color/text_secondary" />

            <ImageView
                android:id="@+id/nav_logo"
                android:layout_width="28dp"
                android:layout_height="28dp"
                android:src="@drawable/ic_leaf_logo" />

            <TextView
                android:id="@+id/nav_app_name"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="6dp"
                android:fontFamily="@font/misans"
                android:text="@string/app_name"
                android:textColor="#8BC34A"
                android:textSize="18sp"
                android:textStyle="bold" />

        </LinearLayout>

        <HorizontalScrollView
            android:layout_width="wrap_content"
            android:layout_height="match_parent"
            android:layout_gravity="center"
            android:layout_marginStart="24dp"
            android:scrollbars="none"
            android:overScrollMode="never">

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="match_parent"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <TextView
                    android:id="@+id/nav_tab_launch"
                    android:layout_width="wrap_content"
                    android:layout_height="match_parent"
                    android:gravity="center"
                    android:paddingHorizontal="12dp"
                    android:fontFamily="@font/misans"
                    android:text="@string/nav_launch"
                    android:textColor="@color/on_surface"
                    android:textSize="13sp"
                    android:textStyle="bold"
                    android:drawableStart="@drawable/ic_nav_launch"
                    android:drawablePadding="5dp"
                    android:background="?attr/selectableItemBackground" />

                <TextView
                    android:id="@+id/nav_tab_instances"
                    android:layout_width="wrap_content"
                    android:layout_height="match_parent"
                    android:gravity="center"
                    android:paddingHorizontal="12dp"
                    android:fontFamily="@font/misans"
                    android:text="@string/nav_instances"
                    android:textColor="@color/text_secondary"
                    android:textSize="13sp"
                    android:drawableStart="@drawable/ic_nav_instances"
                    android:drawablePadding="5dp"
                    android:background="?attr/selectableItemBackground" />

                <TextView
                    android:id="@+id/nav_tab_about"
                    android:layout_width="wrap_content"
                    android:layout_height="match_parent"
                    android:gravity="center"
                    android:paddingHorizontal="12dp"
                    android:fontFamily="@font/misans"
                    android:text="@string/nav_about"
                    android:textColor="@color/text_secondary"
                    android:textSize="13sp"
                    android:drawableStart="@drawable/ic_nav_about"
                    android:drawablePadding="5dp"
                    android:background="?attr/selectableItemBackground" />

                <TextView
                    android:id="@+id/nav_tab_settings"
                    android:layout_width="wrap_content"
                    android:layout_height="match_parent"
                    android:gravity="center"
                    android:paddingHorizontal="12dp"
                    android:fontFamily="@font/misans"
                    android:text="@string/nav_settings"
                    android:textColor="@color/text_secondary"
                    android:textSize="13sp"
                    android:drawableStart="@drawable/ic_nav_settings"
                    android:drawablePadding="5dp"
                    android:background="?attr/selectableItemBackground" />

            </LinearLayout>
        </HorizontalScrollView>

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="match_parent"
            android:layout_gravity="end|center_vertical"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <Button
                android:id="@+id/nav_sign_in_button"
                style="@style/Widget.MaterialComponents.Button"
                android:layout_width="wrap_content"
                android:layout_height="28dp"
                android:minWidth="0dp"
                android:minHeight="0dp"
                android:paddingHorizontal="12dp"
                android:paddingVertical="0dp"
                android:insetTop="0dp"
                android:insetBottom="0dp"
                android:fontFamily="@font/misans"
                android:gravity="center"
                android:includeFontPadding="false"
                android:backgroundTint="@color/primary"
                android:text="@string/sign_in"
                android:textColor="@color/on_primary"
                android:textSize="11sp"
                android:textStyle="bold"
                android:textAllCaps="false"
                android:visibility="gone" />

            <FrameLayout
                android:id="@+id/nav_account_avatar_container"
                android:layout_width="32dp"
                android:layout_height="32dp"
                android:visibility="gone">

                <com.microsoft.xbox.idp.toolkit.CircleImageView
                    android:id="@+id/nav_account_avatar"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:contentDescription="@string/xbox_avatar"
                    android:scaleType="centerCrop"
                    android:src="@drawable/ic_minecraft_cube" />

                <ProgressBar
                    android:id="@+id/nav_avatar_progress"
                    style="?android:attr/progressBarStyleSmall"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:indeterminate="true"
                    android:visibility="gone" />
            </FrameLayout>

        </LinearLayout>

    </FrameLayout>

    <View
        android:id="@+id/nav_divider"
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="@color/divider" />

</LinearLayout>
